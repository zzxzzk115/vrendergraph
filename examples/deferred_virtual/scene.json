{
  "resources": {
    "backbuffer": {
      "imported": true,
      "width": 1280,
      "height": 720,
      "backbuffer_id": 777
    }
  },

  "passes": [
    {
      "type": "gbuffer",
      "outputs": {
        "albedo": "gbuf.albedo",
        "normal": "gbuf.normal",
        "depth":  "gbuf.depth"
      }
    },

    {
      "type": "lighting",
      "inputs": {
        "albedo": "gbuf.albedo",
        "normal": "gbuf.normal",
        "depth":  "gbuf.depth"
      },
      "outputs": {
        "hdr": "scene.hdr"
      }
    },

    {
      "type": "tonemap",
      "inputs": {
        "hdr": "scene.hdr"
      },
      "outputs": {
        "ldr": "scene.ldr"
      }
    },

    {
      "type": "fxaa",
      "inputs": {
        "input": "scene.ldr"
      },
      "outputs": {
        "output": "scene.final"
      }
    },

    {
      "type": "present",
      "inputs": {
        "color": "scene.final",
        "backbuffer": "backbuffer"
      },
      "outputs": {
        "backbuffer": "backbuffer"
      }
    }
  ]

  ,"meta": {
    "editor": {
      "view": {
        "zoom": 1.0,
        "pan": [0.0, 0.0]
      },
      "nodes": {
        "gbuffer":  { "pos": [-300.0,   0.0] },
        "lighting": { "pos": [  50.0, -60.0] },
        "tonemap":  { "pos": [ 400.0,   0.0] },
        "fxaa":     { "pos": [ 700.0,   0.0] },
        "present":  { "pos": [ 980.0,   0.0] }
      }
    }
  }
}